{
  "name": "ink-arena",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @inkarena/client",
    "build": "npm run build --workspaces --if-present",
